TARGETS = []


# Establishing the file targets for the set of "simple" simulations
if config["analyses"]["simple_simulations"]["enable"]:
    with open(
        config["analyses"]["simple_simulations"]["simple_config"], "r"
    ) as simple_config_fp:
        simple_config = yaml.safe_load(simple_config_fp)
    n = simple_config["n"]
    ns = [10, 20, 50, 200]
    seeds = simple_config["seeds"]
    inds = simple_config["inds"]
    for c in simple_config["models"]:
        for v in simple_config["models"][c]["versions"]:
            for s in seeds:
                TARGETS.append(f"results/simulations/outputs/{c}/{v}/n{n}_seed{s}.tsz")
                TARGETS.append(
                    f"results/simulations/outputs/{c}/{v}/n{n}_seed{s}.merged.bed"
                )
                # if c in ["ooa_neanderthal5r19_simp", "split_constant"] and v == "m2_ori":
                if c == "split_constant" and v == "m10_ori":
                    for nss in ns:
                        TARGETS.append(
                            f"results/simulations/outputs/{c}/{v}/n{nss}_seed{s}.tsz"
                        )
                        TARGETS.append(
                            f"results/simulations/outputs/{c}/{v}/n{nss}_seed{s}.merged.bed"
                        )

# Establishing file targets for "wrongly specified input" analysis
if config["analyses"]["error_input"]["enable"]:
    with open(config["analyses"]["error_input"]["config"], "r") as error_input_fp:
        analysis_input = yaml.safe_load(error_input_fp)
    INDS = range(int(analysis_input["error_input"]["inds"]))
    n = analysis_input["error_input"]["n"]
    seeds = analysis_input["error_input"]["seeds"]
    for m in analysis_input["error_input"]["models"]:
        t = analysis_input["error_input"]["models"][m]["t"]
        intros = analysis_input["error_input"]["models"][m]["intro"]
        for v in analysis_input["error_input"]["models"][m]["versions"]:
            for s in seeds:
                for tt in t:
                    if tt == t[2]:
                        for intro in intros:
                            TARGETS.append(
                                f"results/hmm_results/error_input/{m}/{v}/n{n}_seed{s}_{tt}_{intro}_data.tsv"
                            )
                            TARGETS.append(
                                f"results/hmm_results/error_input/{m}/{v}/n{n}_seed{s}_{tt}_{intro}_A_data.tsv"
                            )
                    else:
                        TARGETS.append(
                            f"results/hmm_results/error_input/{m}/{v}/n{n}_seed{s}_{tt}_{intros[2]}_data.tsv"
                        )
                        TARGETS.append(
                            f"results/hmm_results/error_input/{m}/{v}/n{n}_seed{s}_{tt}_{intros[2]}_A_data.tsv"
                        )

# Establishing file targets for "extreme demograhpic models" analysis
if config["analyses"]["extreme_demo"]["enable"]:
    with open(config["analyses"]["extreme_demo"]["config"], "r") as extreme_demo_fp:
        analysis_input = yaml.safe_load(extreme_demo_fp)
    INDS = range(int(analysis_input["extreme_demo"]["inds"]))
    n = analysis_input["extreme_demo"]["n"]
    seeds = analysis_input["extreme_demo"]["seeds"]
    for s in seeds:
        for m in analysis_input["extreme_demo"]["models"]:
            t = analysis_input["extreme_demo"]["models"][m]["t"]
            intro = analysis_input["extreme_demo"]["models"][m]["intro"][0]
            for v in range(
                len(analysis_input["extreme_demo"]["models"][m]["versions"])
            ):
                version = analysis_input["extreme_demo"]["models"][m]["versions"][v]
                if version == "m2_s10k":
                    TARGETS.append(
                        f"results/hmm_results/extreme_demo/{m}/{version}/n{n}_seed{s}_{t[1]}_{intro}_data.tsv"
                    )
                else:
                    TARGETS.append(
                        f"results/hmm_results/extreme_demo/{m}/{version}/n{n}_seed{s}_{t[0]}_{intro}_data.tsv"
                    )

