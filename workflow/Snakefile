            if snpinfo:
                TARGETS.append(
                    # f"results/realdata/{dataset}/snpinfo/1000g_biall_snpinfo.human_ancestor.archaic.afr.outgroup.strictmask.chr{chrom}.txt"
                    f"results/realdata/{dataset}/snpinfo/1000g_biall_snpinfo.human_ancestor.archaic.lwkonly.outgroup.strictmask.manifesto.chr{chrom}.txt"     
                    # f"results/realdata/{dataset}/snpinfo/1000g_biall_snpinfo.human_ancestor.archaic.yri.outgroup.strictmask.mutage.chr{chrom}.txt"
                    # f"results/realdata/{dataset}/snpinfo/hgdp_biall_snpinfo.human_ancestor.archaic.afr.outgroup.strictmask.manifesto.chr{chrom}.txt"
