# Establishing file targets for "inference comparison" analysis
if config["analyses"]["inference_comparison"]["enable"]:
    runhmm = config["analyses"]["inference_comparison"]["analysis"]
    inference = config["analyses"]["inference_comparison"]["infer"]
    with open(
        config["analyses"]["inference_comparison"]["config"], "r"
    ) as inference_comparison_fp:
        analysis_input = yaml.safe_load(inference_comparison_fp)
    INDS = range(int(analysis_input["inference_comparison"]["inds"]))
    n = analysis_input["inference_comparison"]["n"]
    seeds = analysis_input["inference_comparison"]["seeds"]
    inds = analysis_input["inference_comparison"]["inds"]
    for s in seeds:
        for m in analysis_input["inference_comparison"]["models"]:
            t = analysis_input["inference_comparison"]["models"][m]["t"][0]
            intro = analysis_input["inference_comparison"]["models"][m]["intro"][0]
            for v in analysis_input["inference_comparison"]["models"][m]["versions"]:
                if inference:
                    # TARGETS.append(
                    #     f"results/hmm_results/inference_comparison/{m}/{v}/simulations/n{n}_seed{s}_withARC.indiv.bed",
                    # )
                    # TARGETS.append(
                    #     f"results/hmm_results/inference_comparison/{m}/{v}/ibdmix/n{n}_seed{s}_A.ibdmix"
                    # )
                    # TARGETS.append(
                    #     f"results/hmm_results/inference_comparison/{m}/{v}/sprime/n{n}_seed{s}_Sprime.score"
                    # )
                    for j in range(int(inds)):
                        TARGETS.append(
                            f"results/hmm_results/inference_comparison/{m}/{v}/hmmix/n{n}_seed{s}.tsk_{int(j/2)}.hap{int(j%2)+1}.txt"
                        )
                if runhmm:
                    for i in analysis_input["inference_comparison"]["models"][m][
                        "inference"
                    ]:
                        TARGETS.append(
                            f"results/hmm_results/inference_comparison/{m}/{v}/{i}/n{n}_seed{s}_{t}_{intro}_data.tsv"
                        )
                        if i == "singer":
                            TARGETS.append(
                                f"results/hmm_results/inference_comparison/{m}/{v}/{i}/n{n}_seed{s}_{t}_{intro}_cleanup.log"
                            )

# Establishing file targets for arg_infer analysis
if config["analyses"]["arg_infer"]["enable"]:
    runhmm = config["analyses"]["arg_infer"]["analysis"]
    inference = config["analyses"]["arg_infer"]["infer"]
    with open(config["analyses"]["arg_infer"]["config"], "r") as arg_infer_fp:
        analysis_input = yaml.safe_load(arg_infer_fp)
    n = analysis_input["arg_infer"]["n"]
    seeds = analysis_input["arg_infer"]["seeds"]
    INDS = range(int(analysis_input["arg_infer"]["inds"]))
    asamp = analysis_input["arg_infer"]["asamp"]
    for s in seeds:
        for m in analysis_input["arg_infer"]["models"]:
            t = analysis_input["arg_infer"]["models"][m]["t"]
            intro = analysis_input["arg_infer"]["models"][m]["intro"][0]
            for v in analysis_input["arg_infer"]["models"][m]["versions"]:
                if inference:
                    TARGETS.append(
                        f"results/simulations/outputs/{m}/{v}/n{n}_seed{s}_out_full.vcf"
                    )
                    TARGETS.append(
                        f"results/simulations/outputs/{m}/{v}/n{n}_seed{s}_A_full.vcf"
                    )
                    # TARGETS.append(
                    #     f"results/hmm_results/arg_infer/{m}/{v}/relate/n{n}_seed{s}_A.trees"
                    # )
                    # TARGETS.append(
                    #     f"results/hmm_results/arg_infer/{m}/{v}/relate/n{n}_seed{s}_out.trees"
                    # )
                    # TARGETS.append(
                    #     f"results/hmm_results/arg_infer/{m}/{v}/singer/n{n}_seed{s}_A_99.tsz"
                    # )
                    # TARGETS.append(
                    #     f"results/hmm_results/arg_infer/{m}/{v}/singer/n{n}_seed{s}_out_99.tsz"
                    # )
                    # TARGETS.append(
                    #     f"results/hmm_results/arg_infer/{m}/{v}/singer/n{n}_seed{s}_done.log"
                    # )
                if runhmm:
                    for tt in t:
                        if s > 5 and (m == "ooa_neanderthal5r19_comp" or v != "m2_ori"):
                            continue  # skip for now
                        # TARGETS.append(
                        #     f"results/hmm_results/arg_infer/{m}/{v}/singer/n{n}_seed{s}_{tt}_{intro}_data.tsv"
                        # )
                        # TARGETS.append(
                        #     f"results/hmm_results/arg_infer/{m}/{v}/msprime/n{n}_seed{s}_{tt}_{intro}_data.tsv"
                        # )
                        # TARGETS.append(
                        #     f"results/hmm_results/arg_infer/{m}/{v}/relate/n{n}_seed{s}_{tt}_{intro}_data.tsv"
                        # )
                        for ind in INDS:
                            TARGETS.append(
                                f"results/hmm_results/arg_infer/{m}/{v}/relate/n{n}_seed{s}_{tt}_{intro}_ppsind{ind}.npz"
                            )
                            TARGETS.append(
                                f"results/hmm_results/arg_infer/{m}/{v}/msprime/n{n}_seed{s}_{tt}_{intro}_ppsind{ind}.npz"
                            )
                        TARGETS.append(
                            f"results/hmm_results/arg_infer/{m}/{v}/singer/n{n}_seed{s}_{tt}_{intro}_cleanup.log"
                        )

# Establish file targets for realdata analysis
if config["analyses"]["realdata"]["enable"]:
    with open(config["analyses"]["realdata"]["config"], "r") as realdata_fp:
        analysis_input = yaml.safe_load(realdata_fp)
    infer = config["analyses"]["realdata"]["infer"]
    analysis = config["analyses"]["realdata"]["analysis"]
    hmmix = config["analyses"]["realdata"]["hmmix"]
    for dataset in analysis_input["realdata"]["datasets"]:
        for i, chrom in enumerate(
            analysis_input["realdata"]["datasets"][dataset]["chroms"]
        ):
            if infer:
                # TARGETS.append(
                #     f"results/realdata/{dataset}/relate/relate_YRI_GBR/chr{chrom}_YRI_GBR.trees"
                # )
                # TARGETS.append(
                #     f"results/realdata/{dataset}/singer/yri_gbr_chr{chrom}_99.tsz"
                # )
                # TARGETS.append(
                #     f"results/realdata/{dataset}/singer/yri_gbr_chr{chrom}_done.log"
                # )
                TARGETS.append(
                    f"results/realdata/{dataset}/vcf_files/1000g_hg38_chr{chrom}_LWK_flipped.sites"
                )
            if hmmix:
                with open(f"results/realdata/{dataset}/hmmix/individual.json") as file:
                    individuals = json.load(file)
                HMMIX_INGROUP = individuals["ingroup"]
                for ind in HMMIX_INGROUP:
                    TARGETS.append(
                        f"results/realdata/{dataset}/hmmix/02decode/{ind}.hap1.txt"
                    )
            if analysis:
                relate = config["analyses"]["realdata"]["relate"]
                individual_file = (
                    f"results/realdata/{dataset}/GhostHMM/EUR_analysis_samples.txt"
                )
                with open(individual_file) as ind_fp:
                    individuals = ind_fp.readlines()
                    individuals = [x.strip() for x in individuals]
                if relate:
                    for t1 in analysis_input["realdata"]["datasets"][dataset]["t1"]:
                        for t2 in analysis_input["realdata"]["datasets"][dataset]["t2"]:
                            for ind in individuals:
                                chrom_len = analysis_input["realdata"]["datasets"][
                                    dataset
                                ]["chrom_lengths"][i]
                                for start in range(0, chrom_len, 50000000):
                                    end = start + 50000000
                                    TARGETS.append(
                                        f"results/realdata/{dataset}/GhostHMM/relate/{t1}_{t2}/{ind}.hap1.posteriorProb.chr{chrom}_{start}_{end}.txt"
                                    )
                                    TARGETS.append(
                                        f"results/realdata/{dataset}/GhostHMM/relate/{t1}_{t2}/{ind}.hap2.posteriorProb.chr{chrom}_{start}_{end}.txt"
                                    )

if config["analyses"]["summarize"]["enable"]:
